<?xml version="1.0"?>
<model>
  <name>frame_jig</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>Your Name</name>
  </author>
  <description>
    Frame-holding jig for GEPRC Mark 4 7" bottom plate.
    Sized from STL measurements: plate is approx 178x178x2mm.
    Pegs locate the four standoff holes.
    PRIMITIVES BY CHOICE — meshes are unnecessary and worse for a static
    fixture. Refine peg positions when standoff hole locations are confirmed.
  </description>
</model>